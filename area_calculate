          if (link.getAttribute('href') === `#${current}`) {
            link.classList.add('active');
          }
        });
      });
    });
    
    // Calculator function
    function calculateArea() {
      // Get input values
      let y = parseFloat(document.getElementById('y').value);
      let x = parseFloat(document.getElementById('x').value);
      let v = parseFloat(document.getElementById('v').value);
      let u = parseFloat(document.getElementById('u').value);
      let unit = parseInt(document.getElementById('unit').value);
      const projectName = document.getElementById('projectName').value;

      // Validate inputs
      if (isNaN(y) || isNaN(x) || isNaN(v) || isNaN(u)) {
        document.getElementById('output').innerHTML = `
          <h3><i class="fas fa-exclamation-triangle"></i> Error</h3>
          <p>Please enter all four side measurements correctly.</p>
        `;
        document.getElementById('exportButtons').style.display = 'none';
        return;
      }

      // Calculate average lengths
      y = (y + x) / 2;
      v = (v + u) / 2;

      // Convert to standard units (based on the original logic)
      switch(unit) {
        case 1: // Meter
          y = (y * 100) / (2.54 * 99);
          v = (v * 100) / (2.54 * 99);
          break;
        case 2: // Feet
          y = (Math.floor(y) + ((y - Math.floor(y)) * 10 / 12)) * 12 / 99;
          v = (Math.floor(v) + ((v - Math.floor(v)) * 10 / 12)) * 12 / 99;
          break;
        case 3: // Gattha
          break; // No conversion needed
        case 4: // Yard
          y = y * 3 / 99; // Convert yards to gattha
          v = v * 3 / 99;
          break;
        case 5: // Chain
          y = y * 66 / 99; // Convert chains to gattha
          v = v * 66 / 99;
          break;
        default:
          document.getElementById('output').innerHTML = `
            <h3><i class="fas fa-exclamation-triangle"></i> Error</h3>
            <p>Invalid unit selected.</p>
          `;
          document.getElementById('exportButtons').style.display = 'none';
          return;
      }

      // Calculate area in biswansi units (original formula)
      let area = 3 * y * v; // total biswansi units
      
      // Convert to Beegha, Bisva, Biswansi
      let beegha = Math.floor(area / 400);
      area -= beegha * 400;
      let bisva = Math.floor(area / 20);
      area -= bisva * 20;
      let biswansi = area.toFixed(2);

      // Prepare the result
      let result = `
        <h3><i class="fas fa-chart-pie"></i> Calculation Results ${projectName ? `- ${projectName}` : ''}</h3>
        <div class="result-item">
          <span class="result-label"><i class="fas fa-square" style="color: var(--primary)"></i> Traditional Units:</span>
          <span class="result-value">${beegha} Beegha, ${bisva} Bisva, ${biswansi} Biswansi</span>
        </div>
      `;

      // Optional conversions
      const totalBisva = (beegha * 20) + bisva + (parseFloat(biswansi) / 20);
      const showAcre = document.getElementById('showAcre').checked;
      const showHectare = document.getElementById('showHectare').checked;
      const showSqft = document.getElementById('showSqft').checked;
      const showSqm = document.getElementById('showSqm').checked;

      if (showAcre) {
        const acres = totalBisva / 96;
        result += `
          <div class="result-item">
            <span class="result-label"><i class="fas fa-map-marked-alt"></i> Acres:</span>
            <span class="result-value">${acres.toFixed(6)}</span>
          </div>
        `;
      }

      if (showHectare) {
        const hectares = (totalBisva / 96) * 0.404686;
        result += `
          <div class="result-item">
            <span class="result-label"><i class="fas fa-globe-asia"></i> Hectares:</span>
            <span class="result-value">${hectares.toFixed(6)}</span>
          </div>
        `;
      }

      if (showSqft) {
        const sqft = totalBisva * 54.45; // Approximate conversion factor
        result += `
          <div class="result-item">
            <span class="result-label"><i class="fas fa-ruler"></i> Square Feet:</span>
            <span class="result-value">${sqft.toFixed(2)}</span>
          </div>
        `;
      }

      if (showSqm) {
        const sqm = (totalBisva / 96) * 4046.86;
        result += `
          <div class="result-item">
            <span class="result-label"><i class="fas fa-ruler-combined"></i> Square Meters:</span>
            <span class="result-value">${sqm.toFixed(2)}</span>
          </div>
        `;
      }

      // Add calculation details
      result += `
        <div class="divider"></div>
        <div class="result-item">
          <span class="result-label"><i class="fas fa-info-circle"></i> Calculation Method:</span>
          <span class="result-value">Average of opposite sides</span>
        </div>
        <div class="result-item">
          <span class="result-label"><i class="fas fa-calendar-alt"></i> Calculated On:</span>
          <span class="result-value">${new Date().toLocaleString()}</span>
        </div>
      `;

      document.getElementById('output').innerHTML = result;
      document.getElementById('exportButtons').style.display = 'flex';
    }
    
    // Reset form
    function resetForm() {
      document.getElementById('calculatorForm').reset();
      document.getElementById('output').innerHTML = `
        <h3><i class="fas fa-chart-bar"></i> Results</h3>
        <p>Enter your field dimensions and click "Calculate Area"</p>
      `;
      document.getElementById('exportButtons').style.display = 'none';
      
      // Reset map if exists
      if (window.map) {
        window.map.eachLayer(function(layer) {
          if (layer instanceof L.Polygon) {
            window.map.removeLayer(layer);
          }
        });
      }
    }
    
    // Export to PDF
    function exportToPDF() {
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF();
      
      // Add title
      doc.setFontSize(18);
      doc.setTextColor(46, 125, 50);
      doc.text('GeoMeasure Pro - Area Calculation Report', 105, 20, { align: 'center' });
      
      // Add project name if exists
      const projectName = document.getElementById('projectName').value;
      if (projectName) {
        doc.setFontSize(14);
        doc.setTextColor(0, 0, 0);
        doc.text(`Project: ${projectName}`, 105, 30, { align: 'center' });
      }
      
      // Add date
      doc.setFontSize(12);
      doc.text(`Calculated on: ${new Date().toLocaleString()}`, 105, 40, { align: 'center' });
      
      // Add logo
      // doc.addImage(logoData, 'PNG', 10, 10, 30, 15);
      
      // Add results
      doc.setFontSize(12);
      doc.setTextColor(0, 0, 0);
      
      const resultItems = document.querySelectorAll('.result-item');
      let yPosition = 60;
      
      resultItems.forEach((item, index) => {
        if (yPosition > 250) {
          doc.addPage();
          yPosition = 20;
        }
        
        const label = item.querySelector('.result-label').textContent;
        const value = item.querySelector('.result-value').textContent;
        
        doc.setFont('helvetica', 'bold');
        doc.text(label, 20, yPosition);
        doc.setFont('helvetica', 'normal');
        doc.text(value, 150, yPosition, { align: 'right' });
        
        yPosition += 10;
      });
      
      // Add footer
      doc.setFontSize(10);
      doc.setTextColor(100, 100, 100);
      doc.text('© 2024 GeoMeasure Pro - Professional Land Measurement Tools', 105, 285, { align: 'center' });
      
      // Save the PDF
      doc.save('GeoMeasure_Calculation_Report.pdf');
    }
    
    // Export to CSV
    function exportToCSV() {
      let csv = 'Category,Value\n';
      
      const resultItems = document.querySelectorAll('.result-item');
      resultItems.forEach(item => {
        const label = item.querySelector('.result-label').textContent.replace(',', '');
        const value = item.querySelector('.result-value').textContent.replace(',', '');
        csv += `"${label}","${value}"\n`;
      });
      
      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
      const link = document.createElement('a');
      const url = URL.createObjectURL(blob);
      
      link.setAttribute('href', url);
      link.setAttribute('download', 'GeoMeasure_Calculation_Data.csv');
      link.style.visibility = 'hidden';
      
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    }
    
