  <script>
    // Mobile menu toggle
    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const navMenu = document.getElementById('navMenu');
    
    mobileMenuBtn.addEventListener('click', function() {
      navMenu.classList.toggle('show');
    });
    
    // Toggle main calculator content
    const mainClickBar = document.getElementById('mainClickBar');
    const calculatorContent = document.getElementById('calculatorContent');
    
    mainClickBar.addEventListener('click', function() {
      this.classList.toggle('active');
      calculatorContent.classList.toggle('active');
      
      // Rotate arrow icon
      const arrow = this.querySelector('.arrow');
      arrow.style.transform = calculatorContent.classList.contains('active') ? 'rotate(180deg)' : 'rotate(0)';
    });
    
    // Toggle field diagram
    const fieldDiagramBar = document.getElementById('fieldDiagramBar');
    const fieldDiagramContent = document.getElementById('fieldDiagramContent');
    
    fieldDiagramBar.addEventListener('click', function() {
      this.classList.toggle('active');
      fieldDiagramContent.classList.toggle('active');
      
      // Rotate arrow icon
      const arrow = this.querySelector('.arrow');
      arrow.style.transform = fieldDiagramContent.classList.contains('active') ? 'rotate(180deg)' : 'rotate(0)';
      
      // Initialize map if not already done
      if (fieldDiagramContent.classList.contains('active') && !window.mapInitialized) {
        initMap();
        window.mapInitialized = true;
      }
    });
    
    // Initialize map
    function initMap() {
      const map = L.map('map').setView([28.6139, 77.2090], 15);
      
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
      }).addTo(map);
      
      // Add drawing tools
      const drawnItems = new L.FeatureGroup();
      map.addLayer(drawnItems);
      
      const drawControl = new L.Control.Draw({
        edit: {
          featureGroup: drawnItems
        },
        draw: {
          polygon: {
            allowIntersection: false,
            showArea: true
          },
          circle: false,
          marker: false,
          circlemarker: false
        }
      });
      map.addControl(drawControl);
      
      map.on(L.Draw.Event.CREATED, function(event) {
        const layer = event.layer;
        drawnItems.addLayer(layer);
        
        // Calculate area if polygon
        if (layer instanceof L.Polygon) {
          const area = L.GeometryUtil.geodesicArea(layer.getLatLngs()[0]);
          alert(`Area: ${(area / 10000).toFixed(2)} hectares`);
        }
      });
      
      window.map = map;
    }
    
    // Toggle FAQ answers
    function toggleFaq(question) {
      question.classList.toggle('active');
      const answer = question.nextElementSibling;
      answer.classList.toggle('active');
      
      // Rotate chevron icon
      const icon = question.querySelector('i');
      icon.style.transform = answer.classList.contains('active') ? 'rotate(90deg)' : 'rotate(0)';
    }
    
